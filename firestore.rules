rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ユーザードキュメント（plan を保持）。本人のみ閲覧可、書込みはサーバー（決済Webhook）のみ。
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // 組織図メタ情報（タイトル等）
    match /users/{uid}/charts/{chartId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // 各組織図配下のメンバー
      match /members/{memberId} {
        allow read: if (request.auth != null && request.auth.uid == uid)
                    || (exists(/databases/$(database)/documents/users/$(uid)/charts/$(chartId)/_meta/share)
                        && get(/databases/$(database)/documents/users/$(uid)/charts/$(chartId)/_meta/share).data.enabled == true);
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // 各組織図の共有設定（共有リンクはプロプランのみ）
      match /_meta/share {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid
                     && exists(/databases/$(database)/documents/users/$(uid))
                     && get(/databases/$(database)/documents/users/$(uid)).data.plan == 'pro';
      }
    }

    // 旧パス（後方互換 — 移行用に owner read/write のみ許可、最終的には削除予定）
    match /users/{uid}/members/{memberId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid}/_meta/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // 共有トークン: token → { uid, chartId }
    match /shareTokens/{token} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // その他すべて拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
