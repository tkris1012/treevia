# Stripe の price ID (機密ではない / Stripe ダッシュボードの商品 > 料金 で確認)
# このファイルを functions/.env にコピーして実際の値を入れる。
STRIPE_PRICE_LIGHT=price_xxxxxxxxxxxxx
STRIPE_PRICE_PRO=price_yyyyyyyyyyyyy

# シークレットキー類は .env には書かない。以下のコマンドで登録する:
#   firebase functions:secrets:set STRIPE_SECRET_KEY
#   firebase functions:secrets:set STRIPE_WEBHOOK_SECRET
